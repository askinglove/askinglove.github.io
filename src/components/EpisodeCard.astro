---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate?: Date;
  duration?: string;
  tags?: string[];
  featured?: boolean;
}

const { title, description, slug, pubDate, duration, tags = [], featured = false } = Astro.props;

const formattedDate = pubDate
  ? new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(pubDate)
  : undefined;
---

<a
  href={`/episodes/${slug}`}
  class:list={[
    'card block p-6 md:p-8 group',
    featured && 'ring-2 ring-brand-300/30',
  ]}
>
  <!-- Cover placeholder -->
  <div class="w-full aspect-square rounded-xl bg-gradient-to-br from-brand-800 to-brand-900 mb-5 flex items-center justify-center overflow-hidden">
    <span class="text-4xl text-brand-400/60">问</span>
  </div>

  <!-- Meta -->
  {(formattedDate || duration) && (
    <div class="flex items-center gap-3 text-xs text-text-secondary mb-3">
      {formattedDate && <time>{formattedDate}</time>}
      {formattedDate && duration && <span class="text-brand-200">·</span>}
      {duration && <span>{duration}</span>}
    </div>
  )}

  <!-- Title -->
  <h3 class="text-lg font-bold text-text-primary group-hover:text-brand-500 transition-colors duration-200 leading-snug mb-3">
    {title}
  </h3>

  <!-- Description -->
  <p class="text-sm text-text-secondary leading-relaxed line-clamp-3">
    {description}
  </p>

  <!-- Tags -->
  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-xs px-2.5 py-1 rounded-full bg-brand-100 text-brand-600">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
