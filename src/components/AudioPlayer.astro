---
interface Props {
  rssEmbedUrl: string;
  title?: string;
}

const { rssEmbedUrl, title = '问情播客' } = Astro.props;
---

<div class="w-full rounded-xl overflow-hidden bg-white shadow-sm border border-brand-100">
  <iframe
    src={rssEmbedUrl}
    title={`收听: ${title}`}
    width="100%"
    height="200"
    loading="lazy"
    style="border: none;"
    allow="autoplay"
  ></iframe>
</div>
