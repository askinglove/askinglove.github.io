---
import { navLinks, navCta } from '../data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="nav">
  <div class="wrap nav-inner">
    <!-- Brand -->
    <a href="/" class="brand">
      <div class="mark">🎧</div>
      <div>问情播客 AskingLove</div>
    </a>

    <!-- Desktop Nav -->
    <div class="nav-links">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="mobile-btn" aria-label="打开菜单" aria-expanded="false">
      <span id="bar1"></span>
      <span id="bar2"></span>
      <span id="bar3"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu hidden">
    <div class="mobile-menu-inner">
      {navLinks.map((link) => (
        <a href={link.href} class="mobile-link">{link.label}</a>
      ))}
      <a href={navCta.href} class="btn btn-primary mobile-cta">{navCta.label}</a>
    </div>
  </div>
</header>

<style>
  .nav {
    backdrop-filter: blur(16px);
    background: rgba(13, 9, 19, 0.56);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    position: sticky;
    top: 0;
    z-index: 20;
  }
  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
  }
  .brand {
    display: flex;
    gap: 12px;
    align-items: center;
    font-weight: 700;
    color: inherit;
    text-decoration: none;
    font-size: 15px;
  }
  .mark {
    width: 38px;
    height: 38px;
    border-radius: 14px;
    background: linear-gradient(135deg, #8d51bb, #a56bd7);
    display: grid;
    place-items: center;
    box-shadow: 0 0 28px rgba(141, 81, 187, 0.26);
    font-size: 18px;
  }
  .nav-links {
    display: flex;
    gap: 22px;
    color: #cec2d9;
    font-size: 14px;
  }
  .nav-links a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: white;
  }

  /* Mobile button */
  .mobile-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .mobile-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background: #cec2d9;
    transition: all 0.3s ease;
    transform-origin: center;
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    inset: 0;
    top: 71px;
    background: rgba(13, 9, 19, 0.95);
    backdrop-filter: blur(20px);
    z-index: 19;
  }
  .mobile-menu.hidden { display: none; }
  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    padding: 48px 24px;
  }
  .mobile-link {
    color: #f6f1fb;
    text-decoration: none;
    font-size: 18px;
    font-weight: 500;
  }
  .mobile-cta { margin-top: 8px; }

  @media (max-width: 980px) {
    .nav-links { display: none; }
    .mobile-btn { display: flex; }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;

  let open = false;

  btn.addEventListener('click', () => {
    open = !open;
    menu.classList.toggle('hidden', !open);
    btn.setAttribute('aria-expanded', String(open));

    if (open) {
      bar1.style.transform = 'rotate(45deg) translate(2.5px, 2.5px)';
      bar2.style.opacity = '0';
      bar3.style.transform = 'rotate(-45deg) translate(2.5px, -2.5px)';
    } else {
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
    }
  });

  menu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      open = false;
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
    });
  });
</script>
