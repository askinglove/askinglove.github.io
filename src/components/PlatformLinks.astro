---
import { platforms } from '../data/platforms';

interface Props {
  variant?: 'default' | 'compact';
}

const { variant = 'default' } = Astro.props;
---

<div class:list={[
  'flex flex-wrap gap-4',
  variant === 'default' ? 'justify-center' : 'justify-start',
]}>
  {platforms.map((platform) => (
    <a
      href={platform.url}
      target="_blank"
      rel="noopener noreferrer"
      class:list={[
        'inline-flex items-center gap-3 rounded-xl border transition-all duration-300',
        variant === 'default'
          ? 'px-8 py-4 border-brand-200 bg-white hover:border-brand-400 hover:shadow-md text-text-primary'
          : 'px-5 py-2.5 border-brand-200 bg-white hover:border-brand-400 hover:shadow-sm text-text-primary text-sm',
      ]}
    >
      {platform.icon === 'spotify' && (
        <svg class="w-6 h-6 text-[#1DB954]" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
        </svg>
      )}
      {platform.icon === 'rss' && (
        <svg class="w-6 h-6 text-brand-500" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795 0 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-8.18v4.819c12.951.115 23.418 10.603 23.497 23.564h4.503c-.115-15.629-12.781-28.282-28-28.383z" transform="scale(0.85) translate(1.5, 1.5)"/>
        </svg>
      )}
      <span class="font-medium">{platform.name}</span>
    </a>
  ))}
</div>
