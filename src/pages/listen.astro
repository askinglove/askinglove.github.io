---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { platforms } from '../data/platforms';
---

<BaseLayout
  title="收听"
  description="在你习惯的平台收听问情播客 AskingLove。"
>
  <!-- Hero -->
  <div class="wrap" style="padding:112px 0 84px; text-align:center;">
    <div style="display:inline-block; padding:8px 14px; border-radius:999px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); color:#cec2d9; font-size:12px; letter-spacing:0.14em; text-transform:uppercase; margin-bottom:26px;">
      Listen
    </div>
    <h1 style="margin:0 auto 18px; max-width:14ch; font-size:clamp(38px,5.8vw,58px); line-height:1.06; letter-spacing:-0.05em; font-weight:700;">
      收听问情播客
    </h1>
    <div style="max-width:640px; margin:0 auto; color:#cec2d9; font-size:clamp(17px,2vw,19px); line-height:1.85;">
      在你习惯的平台收听
    </div>
  </div>

  <!-- Light section -->
  <div class="light">
    <div class="wrap">

      <!-- Embedded Player -->
      <section>
        <div class="section-head">
          <div class="kicker">Player</div>
          <h2>在线收听</h2>
        </div>
        <div class="card card-lg" style="overflow:hidden; max-width:720px; margin:0 auto;">
          <iframe
            src="https://player.rss.com/askinglove"
            title="问情播客 AskingLove"
            width="100%"
            height="320"
            loading="lazy"
            style="border:none; display:block;"
            allow="autoplay"
          ></iframe>
        </div>
      </section>

      <!-- Platform Links -->
      <section>
        <div class="section-head">
          <div class="kicker">Platforms</div>
          <h2>选择你的平台</h2>
          <div class="sub">选一个你习惯的平台开始收听。</div>
        </div>
        <div style="display:grid; grid-template-columns:repeat(2, minmax(0,1fr)); gap:18px; max-width:600px; margin:0 auto;" class="listen-grid">
          {platforms.map((p) => (
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="card" style="padding:24px; display:flex; justify-content:space-between; align-items:center; text-decoration:none; color:#2c2433;">
              <strong style="font-size:18px;">{p.name}</strong>
              <span style="font-size:18px; color:#6d6376;">→</span>
            </a>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section style="text-align:center;">
        <h2 style="font-size:clamp(26px,3.5vw,38px); letter-spacing:-0.03em; margin-bottom:12px;">不想错过新节目？</h2>
        <p style="color:#6d6376; margin-bottom:24px;">在 Spotify 或 RSS.com 上关注问情播客。</p>
        <a class="btn btn-light" href="/episodes">浏览全部节目</a>
      </section>
    </div>

    <Footer />
  </div>
</BaseLayout>

<style>
  @media (max-width: 720px) {
    .listen-grid { grid-template-columns: 1fr !important; }
  }
</style>
