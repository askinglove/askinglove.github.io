---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { platforms } from '../data/platforms';
---

<BaseLayout
  title="收听"
  description="在你习惯的平台收听问情播客 AskingLove。"
>
  <!-- Hero -->
  <div class="wrap" style="padding-top:112px; padding-bottom:84px; text-align:center;">
    <h1 style="margin:0 auto 20px; font-size:clamp(38px,5.8vw,58px); line-height:1.06; letter-spacing:-0.05em; font-weight:700;">
      在线收听
    </h1>
    <div style="color:#cec2d9; font-size:clamp(17px,2vw,19px); line-height:1.85;">
      选一个你习惯的平台开始收听。
    </div>
  </div>

  <!-- Light section -->
  <div class="light">
    <div class="wrap" style="max-width:560px;">
      <section style="padding-bottom:80px;">
        <div style="display:grid; gap:18px;" class="listen-grid">
          {platforms.map((p) => (
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="platform-card">
              <strong>{p.name}</strong>
              <span class="platform-arrow">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>

      <!-- Newsletter -->
      <section style="padding-bottom:56px;">
        <div style="text-align:center; opacity:0.85;">
          <p style="color:#9688a3; font-size:13px; letter-spacing:0.06em; text-transform:uppercase; font-weight:600; margin:0 0 8px;">Newsletter</p>
          <p style="color:#6d6376; font-size:15px; margin:0 0 14px;">留下你的邮箱，偶尔收到新的内容与动态。</p>
          <a href="https://askinglovepod.substack.com" target="_blank" rel="noopener noreferrer" class="newsletter-btn">
            在 Substack 订阅
          </a>
        </div>
      </section>
    </div>

    <Footer />
  </div>
</BaseLayout>

<style>
  .platform-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 28px;
    min-height: 78px;
    background: white;
    border: 1px solid rgba(44, 36, 51, 0.07);
    border-radius: 20px;
    box-shadow: 0 4px 14px rgba(18, 12, 28, 0.04);
    text-decoration: none;
    color: #2c2433;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .platform-card strong {
    font-size: 18px;
    letter-spacing: -0.01em;
  }
  .platform-arrow {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(141, 81, 187, 0.06);
    color: #8d51bb;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .platform-card:hover {
    border-color: rgba(141, 81, 187, 0.20);
    box-shadow: 0 10px 28px rgba(18, 12, 28, 0.09);
    transform: translateY(-2px);
  }
  .platform-card:hover .platform-arrow {
    background: rgba(141, 81, 187, 0.12);
    transform: translateX(2px);
  }
  .platform-card:active {
    transform: translateY(0);
    box-shadow: 0 4px 12px rgba(18, 12, 28, 0.06);
  }
  .newsletter-btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 16px;
    border-radius: 12px;
    border: 1px solid rgba(44, 36, 51, 0.08);
    background: transparent;
    color: #9688a3;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }
  .newsletter-btn:hover {
    border-color: rgba(141, 81, 187, 0.14);
    color: #8d51bb;
  }
</style>
