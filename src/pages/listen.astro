---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { platforms } from '../data/platforms';
---

<BaseLayout
  title="收听"
  description="在你习惯的平台收听问情播客 AskingLove。"
>
  <!-- Hero -->
  <div class="wrap" style="padding-top:120px; padding-bottom:72px; text-align:center;">
    <h1 style="margin:0 auto 16px; font-size:clamp(38px,5.8vw,58px); line-height:1.06; letter-spacing:-0.05em; font-weight:700;">
      在线收听
    </h1>
    <div style="color:#cec2d9; font-size:clamp(17px,2vw,19px); line-height:1.85;">
      把那些不知道该跟谁说的话，慢慢讲给你听。
    </div>
  </div>

  <!-- Light section -->
  <div class="light" style="padding-top:64px;">
    <div class="wrap" style="max-width:560px;">

      <!-- Player -->
      <section style="padding-bottom:52px;">
        <div style="border-radius:20px; overflow:hidden; border:1px solid rgba(44,36,51,0.07); box-shadow:0 6px 20px rgba(18,12,28,0.06); max-width:600px; margin:0 auto;">
          <iframe
            src="https://player.rss.com/askinglove"
            title="问情播客 AskingLove"
            width="100%"
            height="360"
            style="border:none; display:block;"
            allow="autoplay"
          ></iframe>
        </div>
      </section>

      <!-- Platforms -->
      <section style="padding-bottom:64px;">
        <div style="text-align:center; margin-bottom:22px;">
          <h2 style="font-size:clamp(24px,3vw,30px); letter-spacing:-0.03em; margin:0 0 6px; color:#2c2433;">选择你的平台</h2>
          <p style="color:#9688a3; font-size:14px; margin:0;">选一个你习惯的平台开始收听。</p>
        </div>
        <div style="display:grid; gap:14px;">
          {platforms.map((p) => (
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="platform-card">
              <strong>{p.name === 'Spotify' ? '在 Spotify 收听' : '在 RSS.com 收听'}</strong>
              <span class="platform-arrow">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>

      <!-- Newsletter -->
      <section style="padding-bottom:72px;">
        <div class="newsletter-card">
          <h3 class="newsletter-title">不想错过问情播客的更新？</h3>
          <p class="newsletter-copy">订阅邮件，收到新节目、精选内容和最新动态。</p>
          <a href="https://askinglovepod.substack.com" target="_blank" rel="noopener noreferrer" class="newsletter-cta">
            在 Substack 订阅
          </a>
        </div>
      </section>

    </div>

    <Footer />
  </div>
</BaseLayout>

<style>
  /* Platform cards */
  .platform-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 26px;
    height: 72px;
    background: white;
    border: 1px solid rgba(44, 36, 51, 0.08);
    border-radius: 18px;
    box-shadow: 0 4px 14px rgba(18, 12, 28, 0.04);
    text-decoration: none;
    color: #2c2433;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .platform-card strong {
    font-size: 17px;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .platform-arrow {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(141, 81, 187, 0.07);
    color: #8d51bb;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .platform-card:hover {
    border-color: rgba(141, 81, 187, 0.22);
    box-shadow: 0 10px 28px rgba(18, 12, 28, 0.10);
    transform: translateY(-2px);
  }
  .platform-card:hover .platform-arrow {
    background: rgba(141, 81, 187, 0.14);
    transform: translateX(2px);
  }
  .platform-card:active {
    transform: translateY(0);
    box-shadow: 0 4px 12px rgba(18, 12, 28, 0.06);
  }

  /* Newsletter card */
  .newsletter-card {
    text-align: center;
    padding: 48px 36px;
    background: white;
    border: 1px solid rgba(44, 36, 51, 0.06);
    border-radius: 20px;
    box-shadow: 0 2px 10px rgba(18, 12, 28, 0.025);
  }
  .newsletter-title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #2c2433;
    margin: 0 0 14px;
  }
  .newsletter-copy {
    font-size: 15px;
    color: #9688a3;
    line-height: 1.8;
    margin: 0 0 32px;
  }
  .newsletter-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 24px;
    border-radius: 16px;
    background: linear-gradient(135deg, #8d51bb, #a66cd8);
    color: white;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 8px 20px rgba(141, 81, 187, 0.20);
    transition: all 0.2s ease;
  }
  .newsletter-cta:hover {
    box-shadow: 0 12px 28px rgba(141, 81, 187, 0.28);
    transform: translateY(-1px);
  }
</style>
