---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlatformLinks from '../components/PlatformLinks.astro';
---

<BaseLayout
  title="收听"
  description="在你习惯的平台收听问情播客 AskingLove。"
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-900 to-brand-800 py-20 md:py-28">
    <div class="container-narrow mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        收听问情播客
      </h1>
      <p class="text-brand-200 text-lg">
        在你习惯的平台收听
      </p>
    </div>
  </section>

  <!-- Embedded Player -->
  <section class="section-padding bg-white">
    <div class="container-narrow mx-auto">
      <h2 class="text-xl font-bold text-text-primary mb-6 text-center">
        在线收听
      </h2>
      <div class="max-w-2xl mx-auto rounded-xl overflow-hidden shadow-sm border border-brand-100">
        <iframe
          src="https://player.rss.com/askinglove"
          title="问情播客 AskingLove"
          width="100%"
          height="320"
          loading="lazy"
          style="border: none;"
          allow="autoplay"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Platform Links -->
  <section class="section-padding bg-brand-50">
    <div class="container-narrow mx-auto text-center">
      <h2 class="text-xl font-bold text-text-primary mb-3">
        选择你的平台
      </h2>
      <p class="text-text-secondary text-sm mb-10">
        问情播客正在上线更多平台，敬请关注。
      </p>
      <PlatformLinks />
    </div>
  </section>

  <!-- Subscribe CTA -->
  <section class="section-padding bg-white">
    <div class="container-narrow mx-auto text-center">
      <h2 class="text-2xl font-bold text-text-primary mb-4">
        不想错过新节目？
      </h2>
      <p class="text-text-secondary mb-8 max-w-md mx-auto">
        在 Spotify 或 RSS.com 上关注问情播客，每次更新都会第一时间出现在你的收听列表。
      </p>
      <a href="/episodes" class="btn-outline">
        浏览全部节目
      </a>
    </div>
  </section>
</BaseLayout>
