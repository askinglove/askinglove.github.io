---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allEpisodes = (await getCollection('episodes'))
  .filter((ep) => !ep.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="全部节目"
  description="浏览问情播客的所有节目。关于爱情、关系与情绪的中文播客。"
>
  <!-- Hero -->
  <div class="wrap" style="padding:112px 0 84px; text-align:center;">
    <div style="display:inline-block; padding:8px 14px; border-radius:999px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); color:#cec2d9; font-size:12px; letter-spacing:0.14em; text-transform:uppercase; margin-bottom:26px;">
      Episodes
    </div>
    <h1 style="margin:0 auto 18px; max-width:14ch; font-size:clamp(38px,5.8vw,58px); line-height:1.06; letter-spacing:-0.05em; font-weight:700;">
      全部节目
    </h1>
    <div style="max-width:640px; margin:0 auto; color:#cec2d9; font-size:clamp(17px,2vw,19px); line-height:1.85;">
      每一集都是一段真实的情绪旅程。选一个安静的时刻，慢慢听。
    </div>
  </div>

  <!-- Light section -->
  <div class="light">
    <div class="wrap">
      <section>
        {allEpisodes.length > 0 ? (
          <div style="display:grid; grid-template-columns:repeat(3, minmax(0,1fr)); gap:18px;" class="episodes-grid">
            {allEpisodes.map((episode) => (
              <a href={`/episodes/${episode.id.replace(/\.md$/, '')}`} class="card" style="padding:24px; text-decoration:none; color:#2c2433; display:block; transition:all 0.3s;">
                {/* Cover placeholder */}
                <div style="width:100%; aspect-ratio:1; border-radius:18px; background:radial-gradient(circle at 30% 20%, rgba(255,132,124,0.12), transparent 24%), linear-gradient(180deg,#161021,#1d1428); margin-bottom:18px; display:flex; align-items:center; justify-content:center;">
                  <span style="font-size:36px; color:rgba(199,155,230,0.4);">问</span>
                </div>
                {/* Meta */}
                <div style="font-size:13px; color:#6d6376; margin-bottom:8px;">
                  {new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(episode.data.pubDate)}
                  {episode.data.duration && <span> · {episode.data.duration}</span>}
                </div>
                {/* Title */}
                <strong style="display:block; font-size:20px; line-height:1.2; margin-bottom:10px;">{episode.data.title}</strong>
                {/* Description */}
                <p style="margin:0; color:#6d6376; font-size:15px; line-height:1.8; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;">
                  {episode.data.description}
                </p>
                {/* Tags */}
                {episode.data.tags.length > 0 && (
                  <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:14px;">
                    {episode.data.tags.map((tag: string) => (
                      <span class="tag" style="font-size:12px; padding:6px 10px;">{tag}</span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        ) : (
          <div style="text-align:center; padding:48px 0;">
            <p style="color:#6d6376; font-size:18px;">节目正在路上，敬请期待。</p>
          </div>
        )}
      </section>
    </div>

    <Footer />
  </div>
</BaseLayout>

<style>
  @media (max-width: 980px) {
    .episodes-grid { grid-template-columns: repeat(2, minmax(0,1fr)) !important; }
  }
  @media (max-width: 600px) {
    .episodes-grid { grid-template-columns: 1fr !important; }
  }
</style>
