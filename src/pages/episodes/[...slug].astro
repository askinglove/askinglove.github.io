---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { platforms } from '../../data/platforms';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes');
  return episodes
    .filter((ep) => !ep.data.draft)
    .map((episode) => ({
      params: { slug: episode.id.replace(/\.md$/, '') },
      props: { episode },
    }));
}

const { episode } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(episode.data.pubDate);
---

<BaseLayout
  title={episode.data.title}
  description={episode.data.description}
  ogType="article"
>
  <!-- Hero -->
  <div class="wrap" style="padding-top:105px; padding-bottom:44px; text-align:center;">
    {episode.data.tags.length > 0 && (
      <div style="display:flex; gap:8px; justify-content:center; flex-wrap:wrap; margin-bottom:22px;">
        {episode.data.tags.map((tag: string) => (
          <span style="padding:6px 12px; border-radius:999px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); color:#cec2d9; font-size:12px;">{tag}</span>
        ))}
      </div>
    )}
    <h1 style="margin:0 auto 18px; max-width:16ch; font-size:clamp(34px,5.4vw,54px); line-height:1.08; letter-spacing:-0.05em; font-weight:700;">
      {episode.data.title}
    </h1>
    <div style="max-width:560px; margin:0 auto; color:#cec2d9; font-size:clamp(16px,1.8vw,18px); line-height:1.85;">
      {episode.data.description}
    </div>
  </div>

  <!-- Light section -->
  <div class="light" style="padding-top:48px;">
    <div class="wrap" style="max-width:560px;">

      <!-- Player -->
      <section style="padding-bottom:40px;">
        <div style="border-radius:20px; overflow:hidden; border:1px solid rgba(44,36,51,0.07); box-shadow:0 6px 20px rgba(18,12,28,0.06);">
          <iframe
            src={episode.data.rssEmbedUrl}
            title={`收听: ${episode.data.title}`}
            width="100%"
            height="180"
            style="border:none; display:block;"
            allow="autoplay"
          ></iframe>
        </div>
      </section>

      <!-- Platforms -->
      <section style="padding-bottom:64px;">
        <div style="text-align:center; margin-bottom:16px;">
          <h2 style="font-size:clamp(22px,3vw,28px); letter-spacing:-0.03em; margin:0; color:#2c2433;">在其他平台收听</h2>
        </div>
        <div style="display:grid; gap:14px;" class="platform-grid">
          {platforms.map((p) => (
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="platform-card">
              <strong>{p.name === 'Spotify' ? '在 Spotify 收听' : '在 RSS.com 收听'}</strong>
              <span class="platform-arrow">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>

      <!-- Newsletter -->
      <section style="padding-bottom:64px;">
        <div class="newsletter-card">
          <h3 class="newsletter-title">不想错过问情播客的更新？</h3>
          <p class="newsletter-copy">订阅邮件，收到新节目、精选内容和最新动态。</p>
          <a href="https://askinglovepod.substack.com" target="_blank" rel="noopener noreferrer" class="newsletter-cta">
            在 Substack 订阅
          </a>
        </div>
      </section>

    </div>

    <div style="padding-top:8px;">
      <Footer />
    </div>
  </div>
</BaseLayout>

<style>
  .platform-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 24px;
    height: 72px;
    background: white;
    border: 1px solid rgba(44, 36, 51, 0.08);
    border-radius: 18px;
    box-shadow: 0 4px 14px rgba(18, 12, 28, 0.04);
    text-decoration: none;
    color: #2c2433;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .platform-card strong {
    font-size: 17px;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .platform-arrow {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(141, 81, 187, 0.07);
    color: #8d51bb;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .platform-card:hover {
    border-color: rgba(141, 81, 187, 0.22);
    box-shadow: 0 10px 28px rgba(18, 12, 28, 0.10);
    transform: translateY(-2px);
  }
  .platform-card:hover .platform-arrow {
    background: rgba(141, 81, 187, 0.14);
    transform: translateX(2px);
  }
  .platform-card:active {
    transform: translateY(0);
    box-shadow: 0 4px 12px rgba(18, 12, 28, 0.06);
  }

  .newsletter-card {
    text-align: center;
    padding: 44px 38px;
    background: white;
    border: 1px solid rgba(44, 36, 51, 0.06);
    border-radius: 20px;
    box-shadow: 0 2px 10px rgba(18, 12, 28, 0.025);
  }
  .newsletter-title {
    font-size: 21px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #2c2433;
    margin: 0 0 14px;
  }
  .newsletter-copy {
    font-size: 15px;
    color: #9688a3;
    line-height: 1.8;
    margin: 0 0 32px;
  }
  .newsletter-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 24px;
    border-radius: 16px;
    background: linear-gradient(135deg, #8d51bb, #a66cd8);
    color: white;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 12px rgba(141, 81, 187, 0.10);
    transition: all 0.2s ease;
  }
  .newsletter-cta:hover {
    box-shadow: 0 8px 18px rgba(141, 81, 187, 0.16);
    transform: translateY(-1px);
  }

  @media (max-width: 600px) {
    .platform-grid { grid-template-columns: 1fr !important; }
  }
</style>
