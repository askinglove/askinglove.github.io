---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SubmitForm from '../components/SubmitForm.tsx';
---

<BaseLayout
  title="投稿你的故事"
  description="如果你也有一段不知道该跟谁说的感情经历，欢迎匿名讲给问情播客听。"
>
  <!-- Hero -->
  <div class="wrap" style="padding:105px 0 56px; text-align:center;">
    <div style="display:inline-block; padding:8px 14px; border-radius:999px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); color:#cec2d9; font-size:12px; letter-spacing:0.14em; text-transform:uppercase; margin-bottom:26px;">
      Submit Your Story
    </div>
    <h1 style="margin:0 auto 18px; max-width:10ch; font-size:clamp(40px,6vw,62px); line-height:1.06; letter-spacing:-0.05em; font-weight:700; text-align:center;">
      把你的故事<br>讲给我们听
    </h1>
    <div style="max-width:640px; margin:0 auto; color:#cec2d9; font-size:clamp(17px,2vw,19px); line-height:1.85;">
      如果你也有一段不知道该跟谁说的感情经历，<br>可以匿名讲给我们听。
    </div>
  </div>

  <!-- Light section -->
  <div class="light">
    <div class="wrap">

      <!-- Notes -->
      <section id="notes">
        <div class="section-head">
          <div class="kicker">Notes</div>
          <h2>投稿前先看</h2>
        </div>
        <div style="display:grid; grid-template-columns:repeat(2, minmax(0,1fr)); gap:18px;" class="notes-grid">
          <div class="card note-card">
            <strong>默认匿名</strong>
            <p>投稿时不需要填写真实姓名或联系方式。</p>
          </div>
          <div class="card note-card">
            <strong>我们会认真阅读</strong>
            <p>每一个投稿我们都会认真看。但不是每一个投稿都会被改编成节目。</p>
          </div>
        </div>
      </section>

      <!-- Form -->
      <section id="form">
        <div class="section-head">
          <div class="kicker">Form</div>
          <h2>匿名投稿表单</h2>
        </div>
        <SubmitForm client:visible />
      </section>

      <!-- Newsletter -->
      <section style="padding-bottom:56px;">
        <div class="newsletter-card">
          <h3 class="newsletter-title">不想错过问情播客的更新？</h3>
          <p class="newsletter-copy">订阅邮件，收到新节目、精选内容和最新动态。</p>
          <a href="https://askinglovepod.substack.com" target="_blank" rel="noopener noreferrer" class="newsletter-cta">
            在 Substack 订阅
          </a>
        </div>
      </section>
    </div>

    <div style="padding-top:8px;">
      <Footer />
    </div>
  </div>
</BaseLayout>

<style>
  .note-card {
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
  }
  .note-card strong {
    display: block;
    font-size: 18px;
    margin-bottom: 6px;
  }
  .note-card p {
    margin: 0;
    color: #6d6376;
    line-height: 1.75;
    font-size: 15px;
    flex: 1;
  }
  .newsletter-card {
    text-align: center;
    padding: 32px 32px;
    background: white;
    border: 1px solid rgba(44, 36, 51, 0.06);
    border-radius: 20px;
    box-shadow: 0 2px 10px rgba(18, 12, 28, 0.025);
  }
  .newsletter-title {
    font-size: 21px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #2c2433;
    margin: 0 0 12px;
  }
  .newsletter-copy {
    font-size: 15px;
    color: #9688a3;
    line-height: 1.8;
    margin: 0 0 24px;
  }
  .newsletter-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 28px;
    border-radius: 16px;
    background: linear-gradient(135deg, #8d51bb, #a66cd8);
    color: white;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 6px 16px rgba(141, 81, 187, 0.14);
    transition: all 0.2s ease;
  }
  .newsletter-cta:hover {
    box-shadow: 0 10px 22px rgba(141, 81, 187, 0.20);
    transform: translateY(-1px);
  }
  @media (max-width: 720px) {
    .notes-grid { grid-template-columns: 1fr !important; }
  }
</style>
