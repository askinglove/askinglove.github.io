---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { platforms, socialLinks } from '../data/platforms';
---

<BaseLayout
  title="问情播客 AskingLove"
  description="一档关于爱情、关系与情绪的中文播客。这里聊心动、失望、拉扯，也聊那些你不知道该跟谁说的话。"
>
  <!-- Hero -->
  <div class="wrap" style="padding-top:120px; padding-bottom:100px; text-align:center;">
    <div style="display:inline-block; padding:8px 14px; border-radius:999px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); color:#cec2d9; font-size:12px; letter-spacing:0.14em; text-transform:uppercase; margin-bottom:28px;">
      问情播客 AskingLove
    </div>
    <h1 style="margin:0 auto 38px; max-width:12ch; font-size:clamp(38px,5.8vw,58px); line-height:1.06; letter-spacing:-0.05em; font-weight:700; text-align:center;">
      <span style="display:block; text-align:center;">有些话，</span>
      <span style="display:block; text-align:center;">不知道该跟谁说。</span>
    </h1>
    <div style="max-width:720px; margin:0 auto; color:#cec2d9; font-size:clamp(17px,2vw,19px); line-height:1.85;">
      这里聊心动、失望、拉扯，也聊那些你不知道该跟谁说的话。<br class="hidden-mobile">像一个会认真听你说话的朋友，陪你把乱成一团的情绪理清一点。
    </div>
    <div style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap; margin-top:52px;">
      <a class="btn btn-primary" href="/listen">开始收听</a>
      <a class="btn btn-secondary" href="/submit">投稿你的故事</a>
    </div>
  </div>

  <!-- Light section -->
  <div class="light">
    <div class="wrap">

      <!-- Featured Episode -->
      <section id="episodes">
        <div class="section-head">
          <div class="kicker">Start Here</div>
          <h2>从这里开始听</h2>
        </div>
        <div class="card card-lg" style="overflow:hidden;">
          <div style="display:grid; grid-template-columns:320px 1fr;" class="feature-grid">
            <!-- Cover -->
            <div style="min-height:400px; padding:28px; background:radial-gradient(circle at 22% 18%, rgba(255,132,124,0.18), transparent 24%), radial-gradient(circle at 78% 78%, rgba(199,155,230,0.10), transparent 24%), linear-gradient(180deg,#161021,#1d1428); color:white; display:flex; flex-direction:column; justify-content:space-between;" class="feature-cover">
              <small style="color:#a7d6ff; font-size:11px; letter-spacing:0.18em; text-transform:uppercase;">Featured Episode</small>
              <strong style="font-size:clamp(30px,3vw,38px); line-height:1.12; max-width:6ch;">暗恋是一个人的<br>独角戏</strong>
              <small style="color:#d8c6e6; font-size:11px; letter-spacing:0.16em; text-transform:uppercase;">问情播客 AskingLove</small>
            </div>
            <!-- Copy -->
            <div style="padding:44px 36px; display:flex; flex-direction:column; justify-content:center;" class="feature-copy">
              <div style="color:#6d6376; font-size:14px; margin-bottom:12px;">入口推荐</div>
              <div style="font-size:clamp(30px,3vw,40px); line-height:1.08; letter-spacing:-0.03em; margin-bottom:16px; font-weight:700;">
                你喜欢的，<br>到底是她，<br>还是那个深陷暗恋的自己？
              </div>
              <div style="color:#6d6376; font-size:16px; line-height:1.9; margin-bottom:22px; max-width:34ch;">
                准备好告白，才发现对方<br>在问你怎么送礼物给别的男生。
              </div>
              <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:28px;">
                <span style="padding:7px 12px; border-radius:999px; background:#f2e8f8; color:#9672b0; font-size:13px;">暗恋</span>
                <span style="padding:7px 12px; border-radius:999px; background:#f2e8f8; color:#9672b0; font-size:13px;">单相思</span>
                <span style="padding:7px 12px; border-radius:999px; background:#f2e8f8; color:#9672b0; font-size:13px;">放不下</span>
              </div>
              <div>
                <a class="btn btn-primary" style="padding:16px 28px; font-size:16px;" href="/episodes/dark-crush">收听这一集</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- About -->
      <section id="about">
        <div class="section-head">
          <div class="kicker">About</div>
          <h2>问情播客是什么？</h2>
          <div class="sub">
            你有没有过这样的深夜——翻来覆去睡不着，<br>脑子里全是那个人，也想不通自己为什么这么在意？
          </div>
        </div>
        <div style="display:grid; grid-template-columns:repeat(3, minmax(0,1fr)); gap:18px;" class="three-up">
          <div class="card about-card">
            <strong>不说教</strong>
            <p>不给标准答案，不告诉你"你应该怎样"。</p>
          </div>
          <div class="card about-card">
            <strong>不评判</strong>
            <p>接住那些你不知道该跟谁说的情绪。</p>
          </div>
          <div class="card about-card">
            <strong>像朋友一样</strong>
            <p>心动、失望、拉扯，都可以慢慢说。</p>
          </div>
        </div>
      </section>

      <!-- Belief -->
      <section>
        <div style="text-align:center; padding:74px 28px; border-radius:34px; background:radial-gradient(circle at 50% 10%, rgba(141,81,187,0.18), transparent 30%), linear-gradient(180deg,#171123,#110b18); color:white; box-shadow:0 22px 56px rgba(0,0,0,0.22);">
          <div style="max-width:24ch; margin:0 auto; font-size:clamp(24px,2.8vw,34px); line-height:1.28; letter-spacing:-0.03em;">
            爱是需要学习的能力，<br>
            而你愿意来到这里，<br>
            就已经迈出了最重要的一步。
          </div>
        </div>
      </section>

      <!-- Submit CTA -->
      <section id="submit">
        <div class="section-head">
          <div class="kicker">Submit Your Story</div>
          <h2>把你的故事讲给我们听</h2>
          <div style="max-width:760px; margin:0 auto 28px; color:#6d6376; text-align:center; line-height:1.85;">
            如果你也有一段不知道该跟谁说的感情经历，欢迎匿名投稿给问情播客。
          </div>
        </div>
        <div class="card card-lg" style="padding:38px 34px; background:linear-gradient(180deg,#fff,#f7f0fb); text-align:center;">
          <h3 style="margin:0 0 12px; font-size:clamp(26px,3vw,30px); letter-spacing:-0.02em;">支持匿名投稿</h3>
          <p style="color:#6d6376; line-height:1.85; margin:0 0 32px;">投稿时不需要填写真实姓名或联系方式。</p>
          <a class="btn btn-primary" href="/submit" style="padding:16px 32px; font-size:16px;">开始投稿</a>
        </div>
      </section>

      <!-- Listen -->
      <section id="listen">
        <div class="section-head">
          <div class="kicker">Listen</div>
          <h2>在你习惯的平台收听</h2>
        </div>
        <div style="display:grid; grid-template-columns:repeat(2, minmax(0,1fr)); gap:18px;" class="listen-grid">
          {platforms.map((p) => (
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="platform-card">
              <strong>{p.name}</strong>
              <span class="platform-arrow">→</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Newsletter -->
      <section id="signup" style="padding-bottom:64px;">
        <div style="text-align:center;">
          <div class="kicker" style="font-size:11px;">Newsletter</div>
          <h2 style="font-size:clamp(20px,2.5vw,26px); margin-bottom:8px;">想收到问情播客的更新？</h2>
          <p style="color:#9688a3; font-size:14px; line-height:1.85; margin:0 0 18px;">
            留下你的邮箱，偶尔收到新的内容与动态。
          </p>
          <a href="https://askinglovepod.substack.com" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:6px; padding:11px 18px; border-radius:14px; border:1px solid rgba(44,36,51,0.10); background:white; color:#6d6376; font-size:14px; font-weight:500; text-decoration:none; transition:all 0.2s;" class="newsletter-btn">
            在 Substack 订阅
          </a>
        </div>
      </section>
    </div>

    <Footer />
  </div>
</BaseLayout>

<style>
  /* About cards — uniform height, padding, shadow */
  .about-card {
    padding: 28px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 12px rgba(18, 12, 28, 0.025) !important;
    border-color: rgba(44, 36, 51, 0.06) !important;
  }
  .about-card strong {
    display: block;
    font-size: 20px;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .about-card p {
    margin: 0;
    color: #6d6376;
    line-height: 1.8;
    font-size: 15px;
    flex: 1;
  }

  /* Platform cards — strong clickable feel */
  .platform-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28px 28px;
    min-height: 80px;
    background: white;
    border: 1px solid rgba(44, 36, 51, 0.08);
    border-radius: 24px;
    box-shadow: 0 6px 20px rgba(18, 12, 28, 0.05);
    text-decoration: none;
    color: #2c2433;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .platform-card strong {
    font-size: 19px;
    letter-spacing: -0.01em;
  }
  .platform-arrow {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(141, 81, 187, 0.06);
    color: #8d51bb;
    font-size: 16px;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .platform-card:hover {
    border-color: rgba(141, 81, 187, 0.22);
    box-shadow: 0 12px 32px rgba(18, 12, 28, 0.10);
    transform: translateY(-3px);
  }
  .platform-card:hover .platform-arrow {
    background: rgba(141, 81, 187, 0.12);
    transform: translateX(2px);
  }
  .platform-card:active {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(18, 12, 28, 0.07);
  }

  /* Newsletter button — subdued */
  .newsletter-btn:hover {
    border-color: rgba(141, 81, 187, 0.16);
    color: #8d51bb;
  }

  @media (max-width: 980px) {
    .feature-grid { grid-template-columns: 1fr !important; }
    .three-up { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 720px) {
    .feature-cover { min-height: 280px !important; }
    .feature-copy { padding: 24px !important; }
    .listen-grid { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 430px) {
    h1 { font-size: clamp(38px, 11vw, 52px) !important; }
  }
</style>
