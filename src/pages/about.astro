---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="关于"
  description="了解问情播客 AskingLove —— 一档关于爱情、关系与情绪的中文播客。"
>
  <!-- Hero -->
  <div class="wrap" style="padding:112px 0 84px; text-align:center;">
    <div style="display:inline-block; padding:8px 14px; border-radius:999px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); color:#cec2d9; font-size:12px; letter-spacing:0.14em; text-transform:uppercase; margin-bottom:26px;">
      About
    </div>
    <h1 style="margin:0 auto 18px; max-width:14ch; font-size:clamp(38px,5.8vw,58px); line-height:1.06; letter-spacing:-0.05em; font-weight:700;">
      关于问情播客
    </h1>
    <div style="max-width:640px; margin:0 auto; color:#cec2d9; font-size:clamp(17px,2vw,19px); line-height:1.85;">
      AskingLove
    </div>
  </div>

  <!-- Light section -->
  <div class="light">
    <div class="wrap">

      <!-- What is it -->
      <section>
        <div class="section-head">
          <div class="kicker">What</div>
          <h2>问情播客是什么？</h2>
          <div class="sub">
            你有没有过这样的深夜——翻来覆去睡不着，<br>
            脑子里全是那个人，想不通 ta 为什么那样，<br>
            也想不通自己为什么这么在意？
          </div>
        </div>
        <div style="max-width:680px; margin:0 auto; color:#6d6376; font-size:16px; line-height:1.88; text-align:center;">
          <p>问情播客想做的，不是给你标准答案。我们不说教，不评判，也不想做那个告诉你"你应该怎样"的人。只想像一个会认真听你说话的朋友，陪你把乱成一团的情绪理清一点。</p>
        </div>
      </section>

      <!-- Why -->
      <section>
        <div class="section-head">
          <div class="kicker">Why</div>
          <h2>为什么做这档播客？</h2>
        </div>
        <div style="max-width:680px; margin:0 auto; color:#6d6376; font-size:16px; line-height:1.88; text-align:center;">
          <p>在亲密关系里，我们常常不知道该跟谁说。跟朋友聊怕被评判，跟家人说怕被念叨，跟对方说又怕把关系弄得更复杂。</p>
          <p>问情播客想做的，是成为那个可以安全说出口的地方。你不需要被评价，也不需要装作已经想通了。你只需要把故事慢慢讲出来。</p>
        </div>
      </section>

      <!-- Topics -->
      <section>
        <div class="section-head">
          <div class="kicker">Topics</div>
          <h2>我们聊什么？</h2>
        </div>
        <div style="display:grid; grid-template-columns:repeat(3, minmax(0,1fr)); gap:14px; max-width:600px; margin:0 auto;" class="topic-grid">
          {['暗恋与心动', '分手与放下', '信任与背叛', '沟通与误解', '异地与等待', '婚姻与承诺', '自我价值', '家庭期待', '那些说不出口的'].map((topic) => (
            <div class="card" style="padding:16px 20px; text-align:center;">
              <span style="font-size:14px; color:#6d6376;">{topic}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Belief -->
      <section>
        <div style="text-align:center; padding:74px 28px; border-radius:34px; background:radial-gradient(circle at 50% 10%, rgba(141,81,187,0.18), transparent 30%), linear-gradient(180deg,#171123,#110b18); color:white; box-shadow:0 22px 56px rgba(0,0,0,0.22);">
          <div style="max-width:24ch; margin:0 auto; font-size:clamp(24px,2.8vw,34px); line-height:1.28; letter-spacing:-0.03em;">
            爱是需要学习的能力，<br>
            而你愿意来到这里，<br>
            就已经迈出了最重要的一步。
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section style="text-align:center;">
        <div style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
          <a class="btn btn-primary" href="/listen">开始收听</a>
          <a class="btn btn-light" href="/submit">投稿你的故事</a>
        </div>
      </section>
    </div>

    <Footer />
  </div>
</BaseLayout>

<style>
  @media (max-width: 720px) {
    .topic-grid { grid-template-columns: repeat(2, minmax(0,1fr)) !important; }
  }
</style>
